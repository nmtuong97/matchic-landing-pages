/* ============================================================
   Matchic - Liquid Glass Design System
   Exact match of the Flutter Liquid Glass theme:
   - Multi-layer transparency with depth
   - Dynamic light diffusion through specular highlights
   - Material simulation via blur and gradient effects
   - Subtle micro-motion feedback
   ============================================================ */

/* --- Reset --- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  /* Light mode palette (from LiquidGlassTheme) */
  --bg-light: #EFF6FF;
  --bg-light-alt: #F8FBFF;
  --primary-light: #2196F3;
  --primary-light-variant: #1976D2;
  --secondary-light: #03DAC6;
  --secondary-light-variant: #018786;
  --surface-light: rgba(255, 255, 255, 0.2);
  --surface-light-solid: rgba(255, 255, 255, 0.85);
  --border-light: rgba(0, 0, 0, 0.12);
  --text-primary-light: #1A1A1A;
  --text-secondary-light: #666666;
  --text-disabled-light: #AAAAAA;
  --shadow-light: rgba(0, 0, 0, 0.1);
  --success: #4CAF50;
  --warning: #FF9800;
  --error: #E53935;
  --info: #2196F3;

  /* Dark mode palette (from LiquidGlassTheme) */
  --bg-dark: #0D1117;
  --bg-dark-alt: #161B22;
  --primary-dark: #64B5F6;
  --primary-dark-variant: #42A5F5;
  --secondary-dark: #80CBC4;
  --surface-dark: rgba(58, 74, 92, 0.75);
  --surface-dark-solid: rgba(22, 27, 34, 0.95);
  --border-dark: rgba(255, 255, 255, 0.15);
  --text-primary-dark: #F5F5F5;
  --text-secondary-dark: #CCCCCC;
  --shadow-dark: rgba(0, 0, 0, 0.2);

  /* Glass effect constants */
  --glass-blur: 24px;
  --glass-radius: 20px;
  --glass-border-width: 0.5px;
  --glass-elevation-blur: 10px;

  /* Typography - Inter as primary, matching app */
  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-alt: 'Outfit', sans-serif;

  /* Default mode - dark (app uses dark as default) */
  --bg: var(--bg-dark);
  --bg-alt: var(--bg-dark-alt);
  --primary: var(--primary-dark);
  --primary-variant: var(--primary-dark-variant);
  --secondary: var(--secondary-dark);
  --surface: var(--surface-dark);
  --border: var(--border-dark);
  --text-primary: var(--text-primary-dark);
  --text-secondary: var(--text-secondary-dark);
  --shadow: var(--shadow-dark);

  /* Layout */
  --nav-height: 72px;
  --container: 1200px;

  /* Animation */
  --anim-fast: 150ms cubic-bezier(0.215, 0.61, 0.355, 1);
  --anim-normal: 250ms cubic-bezier(0.215, 0.61, 0.355, 1);
}

/* --- Theme toggle support --- */
@media (prefers-color-scheme: light) {
  :root {
    --bg: var(--bg-light);
    --bg-alt: var(--bg-light-alt);
    --primary: var(--primary-light);
    --primary-variant: var(--primary-light-variant);
    --secondary: var(--secondary-light);
    --surface: var(--surface-light);
    --surface-solid: var(--surface-light-solid);
    --border: var(--border-light);
    --text-primary: var(--text-primary-light);
    --text-secondary: var(--text-secondary-light);
    --shadow: var(--shadow-light);
  }
}

[data-theme="dark"] {
  --bg: var(--bg-dark);
  --bg-alt: var(--bg-dark-alt);
  --primary: var(--primary-dark);
  --primary-variant: var(--primary-dark-variant);
  --secondary: var(--secondary-dark);
  --surface: var(--surface-dark);
  --surface-solid: var(--surface-dark-solid);
  --border: var(--border-dark);
  --text-primary: var(--text-primary-dark);
  --text-secondary: var(--text-secondary-dark);
  --shadow: var(--shadow-dark);
}

[data-theme="light"] {
  --bg: var(--bg-light);
  --bg-alt: var(--bg-light-alt);
  --primary: var(--primary-light);
  --primary-variant: var(--primary-light-variant);
  --secondary: var(--secondary-light);
  --surface: var(--surface-light);
  --surface-solid: var(--surface-light-solid);
  --border: var(--border-light);
  --text-primary: var(--text-primary-light);
  --text-secondary: var(--text-secondary-light);
  --shadow: var(--shadow-light);
}

/* --- Base --- */
html {
  scroll-behavior: smooth;
  font-size: 14px; /* matches bodyMedium = 14px */
}

body {
  font-family: var(--font-sans);
  background: var(--bg);
  color: var(--text-primary);
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background var(--anim-normal), color var(--anim-normal);
}

/* --- Aurora Background (matching aurora_background.dart) --- */
body::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse 600px 400px at 20% 30%, rgba(33, 150, 243, 0.08), transparent 70%),
    radial-gradient(ellipse 500px 300px at 80% 20%, rgba(3, 218, 198, 0.06), transparent 70%),
    radial-gradient(ellipse 400px 400px at 50% 80%, rgba(100, 181, 246, 0.05), transparent 70%);
  z-index: -1;
  pointer-events: none;
}

/* --- Typography (matching liquid_glass_theme.dart TextTheme) --- */
h1, h2, h3, h4, h5, h6 { font-family: var(--font-sans); font-weight: 700; line-height: 1.2; color: var(--text-primary); }

h1 { font-size: clamp(2rem, 5vw, 2.75rem); }     /* displaySmall: 14+10=24px */
h2 { font-size: clamp(1.5rem, 4vw, 2rem); }       /* headlineLarge: 14+8=22px */
h3 { font-size: clamp(1.15rem, 2.5vw, 1.35rem); } /* titleLarge: 14+4=18px */
h4 { font-size: clamp(1rem, 2vw, 1.15rem); }      /* titleMedium: 14+2=16px */

p { color: var(--text-secondary); line-height: 1.6; }

a {
  color: var(--primary);
  text-decoration: none;
  transition: color var(--anim-fast);
}
a:hover { color: var(--secondary); }

/* --- Scrollbar (glass style) --- */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }

/* --- Layout --- */
.container {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 24px;
}

section { padding: 80px 0; }

/* ============================================================
   Navigation (Liquid Glass AppBar)
   ============================================================ */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: var(--nav-height);
  z-index: 100;
  backdrop-filter: blur(var(--glass-blur)) saturate(1.5);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.5);
  background: var(--surface);
  border-bottom: var(--glass-border-width) solid var(--border);
  transition: background var(--anim-normal), border var(--anim-normal);
}

nav .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--nav-height);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.5px;
}

.nav-logo svg { flex-shrink: 0; }

.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
  list-style: none;
}

.nav-links li a {
  padding: 8px 16px;
  color: var(--text-secondary);
  font-size: 0.85rem;
  font-weight: 500;
  border-radius: 12px;
  transition: all var(--anim-fast);
}

.nav-links li a:hover {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
}

/* Nav CTA button - matching ElevatedButton style */
.nav-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 24px !important;
  background: var(--primary) !important;
  color: #fff !important;
  border-radius: 16px !important;
  font-weight: 600 !important;
  font-size: 0.85rem !important;
  box-shadow: 0 2px 8px rgba(33, 150, 243, 0.25);
  transition: all var(--anim-normal) !important;
}

.nav-cta:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(33, 150, 243, 0.35);
  background: var(--primary-variant) !important;
}

/* Mobile Menu */
.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
}

.menu-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: var(--anim-fast);
}

/* ============================================================
   Hero Section
   ============================================================ */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-top: var(--nav-height);
  position: relative;
  overflow: hidden;
}

.hero-content {
  max-width: 800px;
  padding: 40px 0;
}

/* Glass pill badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  background: var(--surface);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  border: var(--glass-border-width) solid var(--border);
  border-radius: 100px;
  font-size: 0.85rem;
  color: var(--primary);
  font-weight: 500;
  margin-bottom: 24px;
}

/* Gradient hero title */
.hero h1 {
  background: linear-gradient(135deg, var(--text-primary) 30%, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20px;
}

.hero p {
  font-size: clamp(1rem, 2vw, 1.15rem);
  max-width: 600px;
  margin: 0 auto 36px;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

/* ============================================================
   Button System (matching ElevatedButton / OutlinedButton / TextButton)
   ============================================================ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  border-radius: 16px; /* matches glassCornerRadius */
  font-weight: 600;
  font-size: 0.85rem;
  letter-spacing: 0.5px;
  cursor: pointer;
  border: none;
  transition: all var(--anim-normal);
  text-decoration: none !important;
  font-family: var(--font-sans);
}

/* Primary = ElevatedButton */
.btn-primary {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 2px 8px rgba(33, 150, 243, 0.25);
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(33, 150, 243, 0.35);
  background: var(--primary-variant);
  color: #fff;
}

/* Secondary = OutlinedButton */
.btn-secondary {
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  color: var(--primary);
  border: 1.5px solid var(--primary);
}

.btn-secondary:hover {
  background: rgba(33, 150, 243, 0.08);
  border-color: var(--primary-variant);
  transform: translateY(-1px);
  color: var(--primary-variant);
}

/* Text button */
.btn-text {
  background: none;
  color: var(--primary);
  padding: 10px 20px;
}

.btn-text:hover {
  background: rgba(33, 150, 243, 0.06);
}

.hero-privacy-note {
  margin-top: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--text-secondary);
  font-size: 0.8rem;
  opacity: 0.7;
}

/* ============================================================
   Section Headers
   ============================================================ */
.section-header {
  text-align: center;
  max-width: 650px;
  margin: 0 auto 56px;
}

.section-header p {
  font-size: 1rem;
  line-height: 1.7;
}

/* Section tag = Chip (matching ChipTheme) */
.section-tag {
  display: inline-block;
  padding: 8px 16px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: var(--glass-border-width) solid var(--border);
  border-radius: 12px;
  font-size: 0.8rem;
  color: var(--primary);
  font-weight: 500;
  letter-spacing: 0.5px;
  margin-bottom: 16px;
}

/* ============================================================
   Card System (matching CardTheme)
   ============================================================ */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
}

.feature-card {
  padding: 28px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: 0.75px solid var(--border);
  border-radius: var(--glass-radius);
  box-shadow: 0 1px 4px var(--shadow);
  transition: all var(--anim-normal);
}

.feature-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 4px 12px var(--shadow);
  border-color: var(--primary);
}

.feature-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px;
  background: rgba(33, 150, 243, 0.08);
  border: var(--glass-border-width) solid rgba(33, 150, 243, 0.2);
  margin-bottom: 16px;
  font-size: 1.4rem;
}

.feature-card h3 {
  margin-bottom: 10px;
  font-weight: 600;
}

.feature-card p {
  font-size: 0.9rem;
  opacity: 0.8;
}

/* ============================================================
   Privacy Section
   ============================================================ */
.privacy-highlights {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.privacy-card {
  text-align: center;
  padding: 32px 20px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: var(--glass-border-width) solid var(--border);
  border-radius: var(--glass-radius);
  transition: all var(--anim-normal);
}

.privacy-card:hover {
  border-color: var(--primary);
  transform: translateY(-2px);
}

.privacy-icon {
  font-size: 2rem;
  margin-bottom: 12px;
}

.privacy-card h3 { margin-bottom: 8px; font-weight: 600; }
.privacy-card p { font-size: 0.85rem; opacity: 0.75; }

/* ============================================================
   Tech Stack / Chips
   ============================================================ */
.tech-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
}

.tech-item {
  padding: 8px 18px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: var(--glass-border-width) solid var(--border);
  border-radius: 12px;
  font-size: 0.8rem;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all var(--anim-fast);
}

.tech-item:hover {
  border-color: var(--primary);
  color: var(--primary);
}

/* ============================================================
   CTA Section
   ============================================================ */
.cta-section {
  text-align: center;
  background: linear-gradient(180deg, var(--surface) 0%, transparent 100%);
  border-top: var(--glass-border-width) solid var(--border);
  border-bottom: var(--glass-border-width) solid var(--border);
}

.cta-section h2 { margin-bottom: 16px; }
.cta-section p { max-width: 550px; margin: 0 auto 32px; }

.cta-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.store-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: 0.75px solid var(--border);
  border-radius: 16px;
  color: var(--text-primary);
  font-weight: 500;
  font-size: 0.85rem;
  transition: all var(--anim-normal);
}

.store-badge:hover {
  border-color: var(--primary);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px var(--shadow);
  color: var(--text-primary);
}

.store-badge svg { width: 22px; height: 22px; fill: currentColor; }

/* ============================================================
   Footer
   ============================================================ */
footer {
  padding: 48px 0 32px;
  border-top: var(--glass-border-width) solid var(--border);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 40px;
}

.footer-brand p {
  margin-top: 12px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  opacity: 0.7;
  max-width: 280px;
}

.footer-col h4 {
  margin-bottom: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-secondary);
  opacity: 0.6;
}

.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer-col a {
  color: var(--text-secondary);
  font-size: 0.85rem;
  font-weight: 400;
}

.footer-col a:hover { color: var(--primary); }

.footer-bottom {
  padding-top: 24px;
  border-top: var(--glass-border-width) solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.8rem;
  color: var(--text-secondary);
  opacity: 0.6;
}

.footer-lang {
  display: flex;
  align-items: center;
  gap: 16px;
}

.footer-lang a {
  color: var(--text-secondary);
  font-size: 0.8rem;
}

.footer-lang a.active { color: var(--primary); }

/* ============================================================
   Policy Pages
   ============================================================ */
.policy-page {
  padding-top: calc(var(--nav-height) + 40px);
  padding-bottom: 80px;
}

.policy-header {
  text-align: center;
  margin-bottom: 48px;
}

.policy-header h1 { margin-bottom: 8px; }

.policy-header .last-updated {
  color: var(--text-secondary);
  font-size: 0.85rem;
  opacity: 0.6;
}

.policy-content {
  max-width: 800px;
  margin: 0 auto;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) * 0.6));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) * 0.6));
  border: 0.75px solid var(--border);
  border-radius: var(--glass-radius);
  padding: 48px;
  box-shadow: 0 2px 8px var(--shadow);
}

.policy-content h2 {
  font-size: 1.25rem;
  font-weight: 700;
  margin: 36px 0 12px;
}

.policy-content h2:first-child { margin-top: 0; }

.policy-content h3 {
  font-size: 1rem;
  font-weight: 600;
  margin: 24px 0 8px;
}

.policy-content p,
.policy-content li {
  color: var(--text-secondary);
  font-size: 0.9rem;
  line-height: 1.8;
  margin-bottom: 12px;
}

.policy-content ul,
.policy-content ol {
  padding-left: 24px;
  margin-bottom: 16px;
}

.policy-content li { margin-bottom: 6px; }

.policy-content strong {
  color: var(--text-primary);
  font-weight: 600;
}

/* Highlight box (matching success container) */
.policy-content .highlight-box {
  padding: 20px 24px;
  background: rgba(76, 175, 80, 0.08);
  border: 0.75px solid rgba(76, 175, 80, 0.25);
  border-radius: 16px;
  margin: 16px 0 24px;
}

.policy-content .highlight-box p {
  color: var(--success);
  font-weight: 500;
}

.policy-content .highlight-box strong {
  color: var(--success);
  font-weight: 700;
}

/* Support cards */
.support-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
  margin: 32px 0;
}

.support-card {
  padding: 28px 20px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 2));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 2));
  border: var(--glass-border-width) solid var(--border);
  border-radius: var(--glass-radius);
  text-align: center;
  transition: all var(--anim-normal);
}

.support-card:hover {
  border-color: var(--primary);
  transform: translateY(-2px);
}

.support-card .icon {
  font-size: 2rem;
  margin-bottom: 12px;
}

.support-card h3 { margin-bottom: 8px; font-weight: 600; }
.support-card p { font-size: 0.85rem; margin-bottom: 16px; opacity: 0.75; }

/* FAQ items */
.faq-item {
  padding: 24px 0;
  border-bottom: var(--glass-border-width) solid var(--border);
}

.faq-item:first-child { padding-top: 0; }

.faq-item h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 8px;
  cursor: default;
}

.faq-item p { font-size: 0.85rem; line-height: 1.7; }

/* ============================================================
   Language Toggle & Theme Toggle
   ============================================================ */
.lang-toggle {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 3));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 3));
  border-radius: 12px;
  border: var(--glass-border-width) solid var(--border);
}

.lang-toggle button {
  padding: 6px 12px;
  background: none;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  color: var(--text-secondary);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.5px;
  transition: all var(--anim-fast);
}

.lang-toggle button.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 1px 4px rgba(33, 150, 243, 0.3);
}

/* Theme toggle button — matches Liquid Glass filter chip style */
.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: var(--surface);
  backdrop-filter: blur(calc(var(--glass-blur) / 3));
  -webkit-backdrop-filter: blur(calc(var(--glass-blur) / 3));
  border: var(--glass-border-width) solid var(--border);
  border-radius: 12px;
  cursor: pointer;
  color: var(--text-secondary);
  transition: all var(--anim-fast);
  padding: 0;
  font-family: var(--font-sans);
}

.theme-toggle:hover {
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-primary);
  border-color: var(--primary);
}

.theme-toggle svg { width: 18px; height: 18px; display: block; }

/* ============================================================
   Responsive
   ============================================================ */
@media (max-width: 768px) {
  .menu-toggle { display: flex; }

  .nav-links {
    display: none;
    position: absolute;
    top: var(--nav-height);
    left: 0;
    right: 0;
    flex-direction: column;
    gap: 4px;
    background: var(--surface-dark-solid);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: var(--glass-border-width) solid var(--border);
    padding: 12px 16px;
  }

  .nav-links.open { display: flex; }

  .nav-links li a {
    display: block;
    padding: 12px 16px;
    border-radius: 12px;
  }

  section { padding: 60px 0; }

  .features-grid { grid-template-columns: 1fr; }
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .policy-content { padding: 28px 20px; }

  .hero-actions, .cta-buttons { flex-direction: column; }
  .btn, .store-badge { width: 100%; justify-content: center; }
}

@media (max-width: 480px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }

  .policy-content h2 { font-size: 1.1rem; }
}

/* ============================================================
   Utility Classes
   ============================================================ */
.text-center { text-align: center; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mt-32 { margin-top: 32px; }
.mb-16 { margin-bottom: 16px; }
.mb-24 { margin-bottom: 24px; }
.mb-32 { margin-bottom: 32px; }

/* Table style for data-deletion page */
.policy-content table { width: 100%; border-collapse: collapse; margin: 16px 0; }
.policy-content th { padding: 12px; text-align: left; color: var(--text-primary); font-weight: 600; font-size: 0.85rem; border-bottom: var(--glass-border-width) solid var(--border); }
.policy-content td { padding: 12px; color: var(--text-secondary); font-size: 0.85rem; border-bottom: var(--glass-border-width) solid var(--border); }
.policy-content tbody tr:last-child td { border-bottom: none; }
