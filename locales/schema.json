{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Matchic i18n Schema",
  "description": "Validation schema for Matchic locale files",
  
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "ogTitle": { "type": "string" },
        "ogDescription": { "type": "string" },
        "twitterTitle": { "type": "string" },
        "twitterDescription": { "type": "string" }
      }
    },

    "nav": {
      "type": "object",
      "required": ["logo", "features", "howItWorks", "privacy", "waitlist"],
      "properties": {
        "logo": { "type": "string" },
        "features": { "type": "string" },
        "howItWorks": { "type": "string" },
        "privacy": { "type": "string" },
        "waitlist": { "type": "string" },
        "language": { "type": "string" }
      }
    },

    "hero": {
      "type": "object",
      "required": ["title", "subtitle", "cta"],
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "cta": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          }
        },
        "trust": {
          "type": "object",
          "properties": {
            "privateAI": { "type": "string" },
            "noAccount": { "type": "string" },
            "offline": { "type": "string" },
            "noTracking": { "type": "string" }
          }
        }
      }
    },

    "trustStrip": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "items": {
          "type": "object",
          "properties": {
            "builtForPrivacy": { "type": "string" },
            "noCloud": { "type": "string" },
            "noTracking": { "type": "string" },
            "simplicity": { "type": "string" }
          }
        }
      }
    },

    "stats": {
      "type": "object",
      "properties": {
        "wardrobeUsed": { "$ref": "#/definitions/stat" },
        "moneyWasted": { "$ref": "#/definitions/stat" },
        "timeDeciding": { "$ref": "#/definitions/stat" },
        "fashionWaste": { "$ref": "#/definitions/stat" }
      }
    },

    "stat": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      }
    },

    "feature": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "step": {
      "type": "object",
      "required": ["number", "title", "description"],
      "properties": {
        "number": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "faqItem": {
      "type": "object",
      "required": ["question", "answer"],
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      }
    },

    "scenario": {
      "type": "object",
      "required": ["title", "style", "items"],
      "properties": {
        "title": { "type": "string" },
        "style": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },

  "type": "object",
  "required": ["_meta", "common", "meta", "nav", "hero", "trustStrip", "problem", "solution", "howItWorks", "features", "privacy", "comparison", "waitlist", "faq", "finalCta", "footer"],
  
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["language", "name", "locale"],
      "properties": {
        "language": { "type": "string" },
        "name": { "type": "string" },
        "locale": { "type": "string" }
      }
    },

    "common": {
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "tagline": { "type": "string" },
        "comingSoon": { "type": "string" },
        "learnMore": { "type": "string" },
        "getStarted": { "type": "string" },
        "download": { "type": "string" },
        "close": { "type": "string" },
        "back": { "type": "string" },
        "next": { "type": "string" },
        "skip": { "type": "string" },
        "save": { "type": "string" },
        "cancel": { "type": "string" },
        "delete": { "type": "string" },
        "edit": { "type": "string" },
        "add": { "type": "string" },
        "remove": { "type": "string" },
        "search": { "type": "string" },
        "filter": { "type": "string" },
        "sort": { "type": "string" },
        "share": { "type": "string" },
        "export": { "type": "string" },
        "import": { "type": "string" },
        "backup": { "type": "string" },
        "restore": { "type": "string" },
        "settings": { "type": "string" },
        "help": { "type": "string" },
        "feedback": { "type": "string" },
        "rateApp": { "type": "string" },
        "privacyPolicy": { "type": "string" },
        "termsOfService": { "type": "string" },
        "eula": { "type": "string" },
        "version": { "type": "string" },
        "copyright": { "type": "string" },
        "allRightsReserved": { "type": "string" }
      }
    },

    "meta": { "$ref": "#/definitions/meta" },
    "nav": { "$ref": "#/definitions/nav" },
    "hero": { "$ref": "#/definitions/hero" },
    "trustStrip": { "$ref": "#/definitions/trustStrip" },

    "problem": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "stats": { "$ref": "#/definitions/stats" }
      }
    },

    "beforeAfter": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "withoutMatchic": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "withMatchic": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "outfitShowcase": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "scenarios": {
          "type": "object",
          "properties": {
            "work": { "$ref": "#/definitions/scenario" },
            "date": { "$ref": "#/definitions/scenario" },
            "gym": { "$ref": "#/definitions/scenario" },
            "weekend": { "$ref": "#/definitions/scenario" }
          }
        }
      }
    },

    "solution": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "points": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "demo": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "states": {
          "type": "object",
          "properties": {
            "empty": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "action": { "type": "string" }
              }
            },
            "scanning": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "tags": {
                  "type": "object",
                  "properties": {
                    "category": { "type": "string" },
                    "color": { "type": "string" },
                    "material": { "type": "string" },
                    "pattern": { "type": "string" }
                  }
                }
              }
            },
            "closet": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "actions": {
                  "type": "object",
                  "properties": {
                    "addMore": { "type": "string" },
                    "pickOccasion": { "type": "string" }
                  }
                }
              }
            },
            "occasion": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "options": {
                  "type": "object",
                  "properties": {
                    "work": { "type": "string" },
                    "weekend": { "type": "string" },
                    "date": { "type": "string" },
                    "rainy": { "type": "string" }
                  }
                }
              }
            },
            "outfit": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" },
                "actions": {
                  "type": "object",
                  "properties": {
                    "shuffle": { "type": "string" },
                    "save": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "controls": {
          "type": "object",
          "properties": {
            "addItem": { "type": "string" },
            "pickOccasion": { "type": "string" },
            "generateOutfit": { "type": "string" },
            "shuffle": { "type": "string" },
            "reset": { "type": "string" }
          }
        }
      }
    },

    "howItWorks": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "steps": {
          "type": "object",
          "properties": {
            "wardrobe": { "$ref": "#/definitions/step" },
            "outfit": { "$ref": "#/definitions/step" },
            "track": { "$ref": "#/definitions/step" }
          }
        }
      }
    },

    "features": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "items": {
          "type": "object",
          "properties": {
            "outfitGenerator": { "$ref": "#/definitions/feature" },
            "autoTagging": { "$ref": "#/definitions/feature" },
            "wardrobeInsights": { "$ref": "#/definitions/feature" },
            "offlineFirst": { "$ref": "#/definitions/feature" },
            "noAccount": { "$ref": "#/definitions/feature" },
            "dataOwnership": { "$ref": "#/definitions/feature" }
          }
        }
      }
    },

    "privacy": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "points": {
          "type": "object",
          "properties": {
            "onDevice": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" }
              }
            },
            "offline": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" }
              }
            },
            "dataControl": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "comparison": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "headers": {
          "type": "object",
          "properties": {
            "feature": { "type": "string" },
            "matchic": { "type": "string" },
            "others": { "type": "string" }
          }
        },
        "rows": {
          "type": "object",
          "properties": {
            "aiProcessing": {
              "type": "object",
              "properties": {
                "feature": { "type": "string" },
                "matchic": { "type": "string" },
                "others": { "type": "string" }
              }
            },
            "photoStorage": {
              "type": "object",
              "properties": {
                "feature": { "type": "string" },
                "matchic": { "type": "string" },
                "others": { "type": "string" }
              }
            },
            "accountRequired": {
              "type": "object",
              "properties": {
                "feature": { "type": "string" },
                "matchic": { "type": "string" },
                "others": { "type": "string" }
              }
            },
            "offlineAccess": {
              "type": "object",
              "properties": {
                "feature": { "type": "string" },
                "matchic": { "type": "string" },
                "others": { "type": "string" }
              }
            },
            "dataExport": {
              "type": "object",
              "properties": {
                "feature": { "type": "string" },
                "matchic": { "type": "string" },
                "others": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "sustainability": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "features": {
          "type": "object",
          "properties": {
            "shopYourCloset": { "$ref": "#/definitions/feature" },
            "trackUsage": { "$ref": "#/definitions/feature" },
            "capsuleWardrobe": { "$ref": "#/definitions/feature" },
            "consciousChoices": { "$ref": "#/definitions/feature" }
          }
        }
      }
    },

    "dataOwnership": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "features": {
          "type": "object",
          "properties": {
            "dataControl": { "$ref": "#/definitions/feature" }
          }
        },
        "cta": { "type": "string" }
      }
    },

    "waitlist": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "form": {
          "type": "object",
          "properties": {
            "emailPlaceholder": { "type": "string" },
            "submitButton": { "type": "string" },
            "privacyNote": { "type": "string" },
            "loading": { "type": "string" },
            "success": { "type": "string" },
            "error": { "type": "string" }
          }
        },
        "stores": {
          "type": "object",
          "properties": {
            "appStore": { "type": "string" },
            "googlePlay": { "type": "string" }
          }
        }
      }
    },

    "faq": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "items": {
          "type": "object",
          "properties": {
            "free": { "$ref": "#/definitions/faqItem" },
            "offline": { "$ref": "#/definitions/faqItem" },
            "photos": { "$ref": "#/definitions/faqItem" },
            "accuracy": { "$ref": "#/definitions/faqItem" },
            "wardrobeSize": { "$ref": "#/definitions/faqItem" },
            "export": { "$ref": "#/definitions/faqItem" },
            "trust": { "$ref": "#/definitions/faqItem" },
            "platforms": { "$ref": "#/definitions/faqItem" }
          }
        }
      }
    },

    "finalCta": {
      "type": "object",
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "cta": { "type": "string" },
        "secondary": { "type": "string" }
      }
    },

    "footer": {
      "type": "object",
      "properties": {
        "product": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "features": { "type": "string" },
            "howItWorks": { "type": "string" },
            "privacy": { "type": "string" },
            "waitlist": { "type": "string" }
          }
        },
        "company": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "about": { "type": "string" },
            "contact": { "type": "string" },
            "press": { "type": "string" }
          }
        },
        "legal": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "privacyPolicy": { "type": "string" },
            "termsOfService": { "type": "string" },
            "eula": { "type": "string" }
          }
        },
        "social": {
          "type": "object",
          "properties": {
            "twitter": { "type": "string" },
            "instagram": { "type": "string" }
          }
        }
      }
    },

    "legalPages": {
      "type": "object",
      "properties": {
        "privacy": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "lastUpdated": { "type": "string" },
            "sections": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "terms": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "lastUpdated": { "type": "string" },
            "sections": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "eula": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "lastUpdated": { "type": "string" },
            "sections": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
